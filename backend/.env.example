# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/1section

# ── JWT ──
JWT_SECRET=your-strong-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Lemon Squeezy (Payment) ──
LEMONSQUEEZY_API_KEY=ls_api_key
LEMONSQUEEZY_API_KEY_DEV=ls_dev_api_key
LEMONSQUEEZY_API_KEY_PROD=ls_prod_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key

# ── Admin ──
ADMIN_EMAIL=admin@example.com

# ── Server ──
PORT=4000
NODE_ENV=development
PUBLIC_URL=http://localhost:4000

# ── Redis (optional) ──
REDIS_URL=